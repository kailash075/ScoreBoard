# Copy to .env. Services read these (with sane localhost defaults if unset).
KAFKA_BROKERS=localhost:19092
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://scoreboard:scoreboard@localhost:5432/scoreboard

INGESTION_PORT=4001
REALTIME_PORT=4003
API_PORT=4004

TOPIC_RAW_EVENTS=match-events-raw

# Manual scorer auth (ingestion)
SCORER_SECRET=change-me-in-prod
# SCORER_USERS='[{"user":"scorer1","pass":"scorepass","id":"scorer1"}]'

# cricketdata.org (cricapi v1) provider adapter
CRICAPI_KEY=your-key-from-cricketdata.org
CRICAPI_BASE=https://api.cricapi.com/v1
POLL_MS=900000    # 15 min -> ~96/day, under the free 100/day cap
